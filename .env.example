# ============================================================
# Integração GLPI → Active Directory
# Copie este arquivo para .env e preencha os valores
# chmod 600 .env (restringir permissões!)
# ============================================================

# --- GLPI ---
GLPI_URL=https://glpi.empresa.local
GLPI_API_TOKEN=seu_user_token_aqui
GLPI_APP_TOKEN=seu_app_token_aqui
GLPI_VERIFY_SSL=true

# --- Active Directory (LDAPS) ---
AD_SERVER=ldaps://dc01.empresa.local
AD_DOMAIN=empresa.local
AD_BASE_DN=DC=empresa,DC=local
AD_USER_OU=OU=Usuarios,DC=empresa,DC=local
AD_BIND_USER=CN=svc-glpi-ad,OU=ServiceAccounts,DC=empresa,DC=local
AD_BIND_PASSWORD=senha_da_conta_de_servico
AD_DEFAULT_COMPANY=Empresa

# --- Webhook ---
WEBHOOK_SECRET=chave_secreta_do_webhook_glpi

# --- Logging ---
LOG_LEVEL=INFO
