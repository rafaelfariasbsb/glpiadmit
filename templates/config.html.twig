{% import 'components/form/fields_macros.html.twig' as fields %}

{% set field_options = { 'full_width': true } %}

{% if cron_health_warning is not empty %}
    <div class="alert alert-warning mb-3">
        <i class="ti ti-alert-triangle me-1"></i>
        {{ cron_health_warning }}
    </div>
{% endif %}

<form method="POST" action="config.form.php" data-track-changes="true">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />

    <div class="row">
        {{ fields.largeTitle(__('AD Connection'), 'ti ti-plug', true) }}

        {{ fields.dropdownYesNo(
            'enabled',
            config['enabled'] ?? '0',
            __('Enabled'),
            field_options
        ) }}

        {{ fields.textField(
            'ad_server',
            config['ad_server'] ?? '',
            __('AD Server'),
            field_options|merge({
                'helper': __('Hostname or IP address (e.g. dc01.empresa.local). Do NOT include ldaps:// prefix.'),
            })
        ) }}

        {{ fields.numberField(
            'ad_port',
            config['ad_port'] ?? '636',
            __('Port'),
            field_options|merge({
                'min': 1,
                'max': 65535,
                'step': 1,
                'helper': __('LDAPS default: 636, LDAP default: 389'),
            })
        ) }}

        {{ fields.dropdownYesNo(
            'ad_use_ssl',
            config['ad_use_ssl'] ?? '1',
            __('Use SSL (LDAPS)'),
            field_options
        ) }}

        {{ fields.textField(
            'ad_bind_dn',
            config['ad_bind_dn'] ?? '',
            __('Bind DN'),
            field_options|merge({
                'helper': __('Service account DN (e.g. CN=svc-glpi,OU=ServiceAccounts,DC=empresa,DC=local)'),
            })
        ) }}

        {{ fields.passwordField(
            'ad_bind_password',
            config['ad_bind_password'] ?? '',
            __('Bind Password'),
            field_options|merge({
                'clearable': true,
            })
        ) }}

        {{ fields.largeTitle(__('AD Structure'), 'ti ti-sitemap') }}

        {{ fields.textField(
            'ad_base_dn',
            config['ad_base_dn'] ?? '',
            __('Base DN'),
            field_options|merge({
                'helper': __('Search base for duplicate checks (e.g. DC=empresa,DC=local)'),
            })
        ) }}

        {{ fields.textField(
            'ad_user_ou',
            config['ad_user_ou'] ?? '',
            __('User OU'),
            field_options|merge({
                'helper': __('OU where new users will be created (e.g. OU=Users,DC=empresa,DC=local)'),
            })
        ) }}

        {{ fields.textField(
            'ad_domain',
            config['ad_domain'] ?? '',
            __('Domain'),
            field_options|merge({
                'helper': __('AD domain name (e.g. empresa.local)'),
            })
        ) }}

        {{ fields.textField(
            'ad_upn_suffix',
            config['ad_upn_suffix'] ?? '',
            __('UPN Suffix'),
            field_options|merge({
                'helper': __('Must start with @ (e.g. @empresa.com)'),
            })
        ) }}

        {{ fields.largeTitle(__('Groups'), 'ti ti-users-group') }}

        {{ fields.textareaField(
            'ad_groups',
            config['ad_groups'] ?? '',
            __('AD Groups'),
            field_options|merge({
                'helper': __('One group DN per line (e.g. CN=VPN-Users,OU=Groups,DC=empresa,DC=local)'),
            })
        ) }}
    </div>

    <div class="card-footer mx-n2 mb-n2 d-flex">
        <button type="submit" name="action" value="test" class="btn btn-outline-secondary">
            <i class="ti ti-plug me-1"></i>
            <span>{{ __('Test Connection') }}</span>
        </button>
        {% if canedit %}
            <button type="submit" name="action" value="save" class="ms-auto btn btn-primary">
                <i class="ti ti-device-floppy me-1"></i>
                <span>{{ _x('button', 'Save') }}</span>
            </button>
        {% endif %}
    </div>
</form>
