msgid "Ticket"
msgstr "Chamado"

msgid "First Name"
msgstr "Nome"

msgid "Last Name"
msgstr "Sobrenome"

msgid "Email"
msgstr "E-mail"

msgid "Status"
msgstr "Status"

msgid "Attempts"
msgstr "Tentativas"

msgid "Error Message"
msgstr "Mensagem de Erro"

msgid "Date Created"
msgstr "Data de Criação"

msgid "Date Modified"
msgstr "Data de Modificação"

msgid "No GLPIADmit queue item for this ticket."
msgstr "Nenhum item na fila GLPIADmit para este chamado."

msgid "GLPIADmit Queue Item"
msgstr "Item da Fila GLPIADmit"

msgid "View Details"
msgstr "Ver Detalhes"

msgid "Process GLPIADmit AD user creation queue"
msgstr "Processar fila de criação de usuários AD do GLPIADmit"

msgid "Pending"
msgstr "Pendente"

msgid "Processing"
msgstr "Processando"

msgid "Done"
